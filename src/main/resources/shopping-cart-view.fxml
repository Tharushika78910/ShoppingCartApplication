<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootVBox"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ShoppingCartController"
      spacing="12">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="%welcome" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <Label text="%select.language" />
    <ComboBox fx:id="languageComboBox" prefWidth="200" />
    <Button text="%confirm.language" onAction="#handleConfirmLanguage" />

    <Label text="%enter.number.of.items" />
    <TextField fx:id="numberOfItemsField" />
    <Button text="%enter.items" onAction="#handleEnterItems" />

    <ScrollPane fitToWidth="true" prefHeight="220">
        <content>
            <GridPane fx:id="itemsGrid" hgap="10" vgap="10">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
            </GridPane>
        </content>
    </ScrollPane>

    <Button text="%calculate.total" onAction="#handleCalculateTotal" />

    <Label fx:id="cartTotalLabel"
           text="%cart.total"
           style="-fx-font-size: 14px; -fx-font-weight: bold;" />
</VBox>